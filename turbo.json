{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "dev": {
      "persistent": true,
      "cache": false
    },
    "build": {
      "dependsOn": ["^build", "clean"],
      "outputs": ["build/**", "dist/**"]
    },
    "start": {
      "dependsOn": ["^start"]
    },
    "clean": {
      "cache": false
    }
  }
}
