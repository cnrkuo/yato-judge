{
  "exclude": ["node_modules", "dist"],
  "compilerOptions": {
    "types": ["vitest/globals", "node"],
    "outDir": "./dist",
    "target": "es2024",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "paths": {
      "@/*": ["./src/*"],
      "$/*": ["./src/modules/*"]
    },
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "incremental": true,
    "skipLibCheck": true
  }
}
